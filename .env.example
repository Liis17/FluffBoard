# GitHub service account: a fine-grained token with Issues read/write permission for this repository.
GitHub__Token=github_pat_replace_me

# The only repository displayed by this FluffBoard instance.
Board__Repository__Owner=octocat
Board__Repository__Name=Hello-World

# Every configured user is seeded into the local SQLite cache at startup.
# Passwords are hashed before being stored; do not commit the real .env file.
Board__Users__0__Username=admin
Board__Users__0__Password=replace-with-a-long-password
Board__Users__0__GitHubLogin=octocat
Board__Users__0__TelegramId=123456789
